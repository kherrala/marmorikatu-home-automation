      "title": "Läsnäoloanturien akku",
      "description": "Latest battery level per room sensor. The living-room FP300 runs on battery, so watch this — a flat/declining trend means it needs charging or a USB-C cable.",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"building_automation\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"presence\")\n  |> filter(fn: (r) => r._field == \"battery\")\n  |> group(columns: [\"room\"])\n  |> last()\n  |> map(fn: (r) => ({r with _field: r.room}))\n  |> keep(columns: [\"_time\", \"_value\", \"_field\"])",
          "refId": "A"
        }
      ]
