      "title": "Läsnäolo huoneittain",
      "description": "Per-room occupancy from the Presence Engine (`presence` measurement, occupied field). Sparse mmWave/PIR reports are held via the engine's linger; a window is 'Läsnä' if occupied at any point in it.",
      "type": "state-timeline",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"building_automation\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"presence\")\n  |> filter(fn: (r) => r._field == \"occupied\")\n  |> aggregateWindow(every: v.windowPeriod, fn: max, createEmpty: false)\n  |> map(fn: (r) => ({r with _field: r.room}))\n  |> keep(columns: [\"_time\", \"_value\", \"_field\"])",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "fieldConfig": {
