      "title": "Optimoijan ohjaukset (toteutuneet päälle/pois)",
      "description": "Actual actuations from the lights-optimizer decision log (`lights_optimizer`, decision in on/off), newest first — with the reason (auto_on_comfort, vacancy_off, away_off, overnight_off, daylight_off, duration_cap …). 'hold' decisions are excluded.",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"building_automation\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"lights_optimizer\")\n  |> filter(fn: (r) => r._field == \"decision\" or r._field == \"reason\")\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> filter(fn: (r) => r.decision == \"on\" or r.decision == \"off\")\n  |> keep(columns: [\"_time\", \"light_name\", \"category\", \"decision\", \"reason\"])\n  |> sort(columns: [\"_time\"], desc: true)\n  |> limit(n: 200)",
          "refId": "A"
        }
      ]
    },
