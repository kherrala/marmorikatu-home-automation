      "title": "Huoneiden valoisuus (lux)",
      "description": "Illuminance reported by the presence sensors — context for the optimizer's darkness-gated auto-on (a light only auto-ons when the sun is below the dark elevation).",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"building_automation\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"presence\")\n  |> filter(fn: (r) => r._field == \"illuminance\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({r with _field: r.room}))\n  |> keep(columns: [\"_time\", \"_value\", \"_field\"])",
          "refId": "A"
        }
      ]
    },
