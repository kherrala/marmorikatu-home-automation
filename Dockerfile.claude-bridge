# Claude Bridge — MCP-powered AI for Kiosk
FROM python:3.12-slim

WORKDIR /app

# Install system deps: ffmpeg for faster-whisper, tini for PID 1 signal/zombie handling
RUN apt-get update && apt-get install -y --no-install-recommends ffmpeg tini wget && rm -rf /var/lib/apt/lists/*

# Install dependencies
RUN pip install --no-cache-dir "numpy<2" && \
    pip install --no-cache-dir anthropic mcp uvicorn starlette httpx faster-whisper

# Install piper TTS binary (arch-aware) for fast local Finnish speech synthesis
RUN wget -q -O /tmp/piper.tar.gz \
      "https://github.com/rhasspy/piper/releases/download/2023.11.14-2/piper_linux_$(uname -m).tar.gz" && \
    tar -xzf /tmp/piper.tar.gz -C /usr/local && \
    rm /tmp/piper.tar.gz

# Download Finnish Piper voice model (AsmoKoskinen/Piper_Finnish_Model, CC-BY-NC-4.0)
RUN mkdir -p /models && \
    wget -q -O /models/fi_FI-asmo-medium.onnx \
      "https://huggingface.co/AsmoKoskinen/Piper_Finnish_Model/resolve/main/fi_FI-asmo-medium.onnx" && \
    wget -q -O /models/fi_FI-asmo-medium.onnx.json \
      "https://huggingface.co/AsmoKoskinen/Piper_Finnish_Model/resolve/main/fi_FI-asmo-medium.onnx.json"

# Copy bridge script
COPY scripts/claude_bridge.py /app/

# Environment variables (defaults, override in docker-compose)
ENV MCP_URL=http://mcp:3001/mcp
ENV CLAUDE_MODEL=claude-haiku-4-5-20251001
ENV BRIDGE_PORT=3002

# Expose the bridge port
EXPOSE 3002

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:3002/health')" || exit 1

# Run the bridge under tini (reaps zombie child processes from ffmpeg/whisper)
ENTRYPOINT ["tini", "--"]
CMD ["python", "/app/claude_bridge.py"]
