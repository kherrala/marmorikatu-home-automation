FROM python:3.12-slim
WORKDIR /app
RUN pip install --no-cache-dir httpx uvicorn starlette icalendar recurring-ical-events
COPY scripts/calendar_server.py /app/
COPY templates/calendar/ /app/templates/calendar/
ENV CALENDAR_TEMPLATE_DIR=/app/templates/calendar
EXPOSE 3022
CMD ["python", "-u", "/app/calendar_server.py"]
