server {
    listen 80;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;

    ssl_certificate     /etc/nginx/ssl/kiosk.crt;
    ssl_certificate_key /etc/nginx/ssl/kiosk.key;

    root /usr/share/nginx/html;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # Grafana proxy (serves Grafana over HTTPS so session cookies work)
    location /grafana/ {
        proxy_pass http://grafana:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Grafana WebSocket (live dashboard updates)
    location /grafana/api/live/ws {
        proxy_pass http://grafana:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
    }

    # InfluxDB proxy (avoids CORS from browser)
    location /api/influxdb/ {
        proxy_pass http://influxdb:8086/;
        proxy_set_header Host influxdb;
    }

    # Ollama proxy (URL injected via envsubst)
    location /api/ollama/ {
        proxy_pass ${OLLAMA_URL}/;
        proxy_read_timeout 30s;
        proxy_connect_timeout 5s;
    }

    # Config endpoint: exposes non-secret settings + optional API keys to the browser
    location = /api/config {
        default_type application/json;
        return 200 '{"ollamaModel":"${OLLAMA_MODEL}","openaiApiKey":"${OPENAI_API_KEY}","anthropicApiKey":"${ANTHROPIC_API_KEY}"}';
    }

    # Nysse bus timetables SPA (same-origin proxy to avoid cross-origin issues)
    location /nysse/ {
        proxy_pass http://host.docker.internal:3010/;
        proxy_set_header Host $host;
    }

    # Nysse SPA assets (bundled JS/CSS use absolute /assets/ paths)
    location /assets/ {
        proxy_pass http://host.docker.internal:3010;
        proxy_set_header Host $host;
    }

    # Nysse API endpoints (absolute paths from the SPA JS bundle)
    location ~ ^/api/(departures|vehicles|onward-calls|version) {
        proxy_pass http://host.docker.internal:3010;
        proxy_set_header Host $host;
    }

    # Proxy WAGO WebVisu static files, strip framing restrictions
    location /webvisu/ {
        proxy_pass        https://192.168.1.10/webvisu/;
        proxy_set_header  Host             192.168.1.10;
        proxy_ssl_verify  off;
        proxy_hide_header X-Frame-Options;
        proxy_hide_header Content-Security-Policy;
    }

    # Proxy WAGO WebVisu runtime endpoints (absolute paths used by webvisu.js)
    location /WebVisuV3.bin {
        proxy_pass        https://192.168.1.10/WebVisuV3.bin;
        proxy_set_header  Host             192.168.1.10;
        proxy_ssl_verify  off;
    }

    location /plclist.xml {
        proxy_pass        https://192.168.1.10/plclist.xml;
        proxy_set_header  Host             192.168.1.10;
        proxy_ssl_verify  off;
    }
}
