# Plain HTTP certificate server on port 8888 (no HSTS, no redirects)
# iOS: browse to http://192.168.1.160:8888 in Safari to install the cert
server {
    listen 8888;
    root /usr/share/nginx/cert;
    index kiosk.cer;

    default_type application/x-x509-ca-cert;
    add_header Content-Disposition 'attachment; filename="kiosk.cer"';
}

server {
    listen 80;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;

    ssl_certificate     /etc/nginx/ssl/kiosk.crt;
    ssl_certificate_key /etc/nginx/ssl/kiosk.key;

    # Re-resolve Docker service hostnames every 10s so container IP changes
    # (from restarts/rebuilds) are picked up without restarting nginx.
    resolver 127.0.0.11 valid=10s;

    root /usr/share/nginx/html;
    index index.html;

    # Serve the self-signed certificate for easy iOS trust installation
    # On iOS Safari: browse to http://<ip>/cert → Settings > Profiles > Install,
    # then Settings > General > About > Certificate Trust Settings > enable full trust
    location = /cert {
        alias /etc/nginx/ssl/kiosk.cer;
        default_type application/x-x509-ca-cert;
        add_header Content-Disposition 'attachment; filename="kiosk.cer"';
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    # Grafana proxy (serves Grafana over HTTPS so session cookies work)
    location /grafana/ {
        set $backend_grafana grafana:3000;
        proxy_pass http://$backend_grafana;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Grafana WebSocket (live dashboard updates)
    location /grafana/api/live/ws {
        set $backend_grafana_ws grafana:3000;
        proxy_pass http://$backend_grafana_ws;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
    }

    # InfluxDB proxy (avoids CORS from browser)
    location /api/influxdb/ {
        set $backend_influxdb influxdb:8086;
        rewrite ^/api/influxdb(/.*)$ $1 break;
        proxy_pass http://$backend_influxdb;
        proxy_set_header Host influxdb;
    }

    # Claude Bridge proxy (MCP-powered AI + transcription + TTS)
    location /api/chat/ {
        set $backend_bridge claude-bridge:3002;
        rewrite ^/api/chat(/.*)$ $1 break;
        proxy_pass http://$backend_bridge;
        proxy_read_timeout 120s;
        proxy_connect_timeout 10s;
        proxy_send_timeout 120s;
        proxy_buffering off;
        client_max_body_size 10m;
    }

    # Weather widget
    location /weather/ {
        set $backend_weather weather:3020;
        rewrite ^/weather(/.*)$ $1 break;
        proxy_pass http://$backend_weather;
        proxy_set_header Host $host;
    }

    # News headlines widget
    location /news/ {
        set $backend_news news:3021;
        rewrite ^/news(/.*)$ $1 break;
        proxy_pass http://$backend_news;
        proxy_set_header Host $host;
    }

    # Family calendar widget
    location /calendar/ {
        set $backend_calendar calendar:3022;
        rewrite ^/calendar(/.*)$ $1 break;
        proxy_pass http://$backend_calendar;
        proxy_set_header Host $host;
    }

    # Nysse bus timetables SPA (same-origin proxy to avoid cross-origin issues)
    location /nysse/ {
        proxy_pass http://host.docker.internal:3010/;
        proxy_set_header Host $host;
    }

    # Nysse SPA assets (bundled JS/CSS use absolute /assets/ paths)
    location /assets/ {
        proxy_pass http://host.docker.internal:3010;
        proxy_set_header Host $host;
    }

    # Nysse API endpoints (absolute paths from the SPA JS bundle)
    location ~ ^/api/(departures|vehicles|onward-calls|version) {
        proxy_pass http://host.docker.internal:3010;
        proxy_set_header Host $host;
    }

    # Proxy WAGO WebVisu static files, strip framing restrictions
    location /webvisu/ {
        proxy_pass        https://192.168.1.10/webvisu/;
        proxy_set_header  Host             192.168.1.10;
        proxy_ssl_verify  off;
        proxy_hide_header X-Frame-Options;
        proxy_hide_header Content-Security-Policy;
    }

    # Proxy WAGO WebVisu runtime endpoints (absolute paths used by webvisu.js)
    location /WebVisuV3.bin {
        proxy_pass        https://192.168.1.10/WebVisuV3.bin;
        proxy_set_header  Host             192.168.1.10;
        proxy_ssl_verify  off;
    }

    location /plclist.xml {
        proxy_pass        https://192.168.1.10/plclist.xml;
        proxy_set_header  Host             192.168.1.10;
        proxy_ssl_verify  off;
    }
}
